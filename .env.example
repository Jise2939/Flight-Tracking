# .env.example
# 将此文件复制为 .env 并填写实际 API Key
# 不要在版本控制中提交包含真实密钥的 .env 文件

# AeroDataBox (via RapidAPI)
AERODATABOX_API_KEY=REPLACE_WITH_YOUR_KEY
AERODATABOX_RAPIDAPI_KEY=REPLACE_WITH_YOUR_KEY
AERODATABOX_API_BASE=https://aerodatabox.p.rapidapi

# FlightRadar24 via RapidAPI
FR24_RAPIDAPI_KEY=REPLACE_WITH_YOUR_KEY

# Rate limiting / retry settings
RATE_LIMIT=100
MAX_RETRIES=3
RETRY_DELAY=5

# 说明：将所有 REPLACE_WITH_YOUR_KEY 替换为真实的密钥，
# 并确保将 .env 加入 .gitignore（已在仓库中配置）。
