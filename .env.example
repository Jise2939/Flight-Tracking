# API Configuration
# 复制此文件为 .env 并填写你的 API Key

# AviationStack API
# 获取免费API Key: https://aviationstack.com/
AVIATIONSTACK_API_KEY=your_aviationstack_key_here

# AeroDataBox API (通过RapidAPI)
# 获取免费API Key: https://rapidapi.com/aedbx-aedbx/api/aerodatabox
AERODATABOX_API_KEY=your_aerodatabox_key_here

# API Configuration
AVIATIONSTACK_API_BASE=https://api.aviationstack.com/v1
AERODATABOX_API_BASE=https://aerodatabox.p.rapidapi

# Rate Limiting (requests per minute)
RATE_LIMIT=100